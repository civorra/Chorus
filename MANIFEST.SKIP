# Version control
^\.git/
\.gitignore

# ECA / session artefacts
^eca/sessions/
^eca/skills/cpan-release\.md$
^\.eca/

# Meta files (ECA / Claude — not part of the CPAN distribution)
^AGENTS\.md$
^CLAUDE\.md$
^\.claude/

# MCP server (not part of the CPAN distribution)
^mcp/

# User sandboxes (not part of the CPAN distribution — examples/sandboxes/ is kept)
^sandboxes/

# Build artefacts
^blib/
^_build/
^Makefile$
^MYMETA\.(yml|json)$
^pm_to_blib
^\.lwpcookies
^cover_db/
^nytprof/
^MANIFEST\.bak$

# Distribution tarballs
\.tar\.gz$
\.zip$
Chorus-Engine-

# Temp / editor files
~$
\.swp$
\.orig$
