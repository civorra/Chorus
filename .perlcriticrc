# perform perlcricit in 'stern' mode
severity = 4

# Add some modules that imports 'use strict'
[TestingAndDebugging::RequireUseStrict]
equivalent_modules = Modern::Perl Test::Class::Moose Test::Most Newt::Moose Newt::Moose::Role Newt::Moose::Controller Newt::Moose::Role::Controller

# Add some modules that imports 'use warnings'
[TestingAndDebugging::RequireUseWarnings]
equivalent_modules = Modern::Perl Test::Class::Moose Test::Most Newt::Moose Newt::Moose::Role Newt::Moose::Controller Newt::Moose::Role::Controller

[Variables::RequireLocalizedPunctuationVars]
allow = %ENV $ENV

# Permit UTF-8 module names
[Modules::RequireExplicitPackage]
allow_import_of = utf8

# Allow no strict 'refs'
[TestingAndDebugging::ProhibitNoStrict]
allow = refs

# Allow no warnings 'redefine'
[TestingAndDebugging::ProhibitNoWarnings]
allow = redefine

# Extends the maximun lines between 'open' and its 'close' statement
[InputOutput::RequireBriefOpen]
lines = 20

# Allow not depacking @_ for short sub
[Subroutines::RequireArgUnpacking]
short_subroutine_statements = 1



# Unloads policies

[-Subroutines::RequireFinalReturn]
[-Subroutines::ProhibitSubroutinePrototypes]
[-Subroutines::ProhibitBuiltinHomonyms]
[-Perl::Critic::Policy::ControlStructures::ProhibitYadaOperator]
[-Perl::Critic::Policy::Variables::ProhibitConditionalDeclarations]
